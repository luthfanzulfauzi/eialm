import { StatsCard } from "@/components/dashboard/StatsCard";
import { AuditTrail } from "@/components/dashboard/AuditTrail";
import { Server, Globe, ShieldAlert, Activity } from "lucide-react";

export default async function DashboardPage() {
  // In a real scenario, you'd fetch this from your API/Service
  const stats = [
    { title: "Total Infrastructure", value: "1,284", icon: Server, trend: { value: "12%", isUp: true } },
    { title: "Public IP Pool", value: "64 / 128", icon: Globe, iconColor: "text-emerald-400" },
    { title: "Maintenance Alerts", value: "12", icon: ShieldAlert, iconColor: "text-amber-400" },
    { title: "Network Uptime", value: "99.9%", icon: Activity, iconColor: "text-purple-400" },
  ];

  return (
    <div className="space-y-8">
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {stats.map((stat, idx) => (
          <StatsCard key={idx} {...stat} />
        ))}
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div className="lg:col-span-2 bg-[#151921] border border-slate-800 rounded-2xl p-6">
          <h3 className="text-lg font-bold text-white mb-6">Recent Asset Movements</h3>
          <AuditTrail logs={[]} /> {/* Pass real logs here */}
        </div>
        
        <div className="bg-[#151921] border border-slate-800 rounded-2xl p-6">
          <h3 className="text-lg font-bold text-white mb-4">Quick Actions</h3>
          <div className="space-y-3">
             <button className="w-full py-3 bg-blue-600 rounded-xl font-bold text-sm hover:bg-blue-700 transition-all">Generate Inventory Report</button>
             <button className="w-full py-3 bg-slate-800 rounded-xl font-bold text-sm border border-slate-700 hover:bg-slate-700 transition-all">Audit IP Assignments</button>
          </div>
        </div>
      </div>
    </div>
  );
}