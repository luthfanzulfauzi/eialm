# Shared app settings
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000
CRON_SECRET=replace-with-a-long-random-secret
OBSERVABILITY_TOKEN=replace-with-a-long-random-secret

# Local development outside Docker
DATABASE_URL=postgresql://admin:password123@localhost:5432/eialm_db?schema=public
NODE_ENV=development

# Docker Compose database settings
# Compose builds the in-container DATABASE_URL from these values and the db service name.
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=eialm_db

# Optional reverse proxy settings
HTTP_PORT=80
HTTPS_PORT=443
TLS_CERTS_DIR=./deploy/nginx/certs
LOG_MAX_SIZE=10m
LOG_MAX_FILE=5

# Optional scheduled backup profile
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14

# Initial admin seed account
ADMIN_EMAIL=admin@eialm.internal
ADMIN_PASSWORD=change-this-admin-password
